---
import Layout from './Layout.astro';

interface Props {
  title: string;
  pubDate: string;
  tags?: string[];
  category?: string;
  description?: string;
}

const { title, pubDate, tags = [], category = '技术', description } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} - Crazy Mark`} description={description}>
  <a href="/" class="back-link">← 返回首页</a>

  <article>
    <div class="article-header">
      <a href={`/category/${category}/`} class="article-category">{category}</a>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </div>

    <div class="article-content">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .article-category {
    display: inline-block;
    background: #f0f4ff;
    color: #3b5bdb;
    padding: 0.2rem 0.7rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }
  .article-category:hover {
    background: #e0e7ff;
  }
</style>
