---
import Layout from './Layout.astro';

interface Props {
  title: string;
  pubDate: string;
  tags?: string[];
  category?: string;
  description?: string;
}

const { title, pubDate, tags = [], category = '技术', description } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// 分类配色
const categoryColors: Record<string, { bg: string; text: string }> = {
  'iOS': { bg: '#f0fdf4', text: '#15803d' },
  '技术': { bg: '#eff6ff', text: '#2563eb' },
  '设计': { bg: '#fdf4ff', text: '#a21caf' },
  '工具': { bg: '#fff7ed', text: '#c2410c' },
  '技术调研': { bg: '#f0f4ff', text: '#4f46e5' },
};
const catStyle = categoryColors[category] || categoryColors['技术'];
---

<Layout title={`${title} - Crazy Mark`} description={description}>
  <a href="/" class="back-link">← 返回首页</a>

  <article>
    <div class="article-header">
      <a href={`/category/${category}/`} class="article-category" style={`background:${catStyle.bg};color:${catStyle.text}`}>{category}</a>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </div>

    <div class="article-content">
      <slot />
    </div>
  </article>
</Layout>

<style>
  .article-category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    text-decoration: none;
  }
  .article-category:hover {
    filter: brightness(0.95);
  }
</style>
